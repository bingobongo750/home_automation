# Copy to .env and fill in real values. .env is gitignored.

# Serial port for the Arduino Uno (find yours with: ls /dev/tty.usb*)
SERIAL_PORT=/dev/tty.usbmodem14101
SERIAL_BAUD=115200

# SQLite database path. Point this at the mounted 1TB SSD in production, e.g.
# /Volumes/SSD/home_automation/sensors.db
DB_PATH=./data/home.db

# myStrom WiFi Switch local IPs (give them static DHCP reservations on the
# router). Plug 2 is seeded as a placeholder until it's physically installed.
MYSTROM_PLUG_IP=192.168.1.50
MYSTROM_PLUG2_IP=192.168.1.51

# Poll interval in seconds for the myStrom plug (state + power draw)
MYSTROM_POLL_INTERVAL=10

# Flask bind address/port
HOST=0.0.0.0
PORT=8000

# Set to 1 to run without any physical hardware: fakes Arduino sensor data
# and myStrom plug responses so the dashboard is developable on its own.
MOCK_HARDWARE=0
